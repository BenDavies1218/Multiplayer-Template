      "leg": {
        "damage": 0.5,
        "shape": { "type": "Capsule", "radius": 0.1, "half_height": 0.25 }
      }
    }
  },
  "world_assets": {
    "visual_path": "models/world_static.glb",
    "dynamic_path": "models/world_dynamic.glb",
    "zones_path": "models/world_zones.glb",
    "skybox_path": "sunset_sky_hdr_cubemap.exr"
