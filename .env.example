# ==============================================
# Multiplayer Template - Environment Variables
# ==============================================
# Copy this file to .env and customize for your environment
# cp .env.example .env

# ============= Server Configuration =============
# Server address (0.0.0.0 for Docker, 127.0.0.1 for local)
SERVER_HOST=127.0.0.1
SERVER_PORT=5000

# Transport protocol: udp, websocket, webtransport
TRANSPORT_TYPE=webtransport

# ============= Network Configuration =============
# Fixed timestep frequency (Hz) - physics update rate
FIXED_TIMESTEP_HZ=64

# Send interval frequency (Hz) - network update rate
SEND_INTERVAL_HZ=64

# Client timeout (seconds) - disconnect inactive clients
CLIENT_TIMEOUT_SECS=3

# ============= Logging Configuration =============
# Log level: error, warn, info, debug, trace
# Use 'debug' for development, 'info' for production
RUST_LOG=info

# ============= Certificate Configuration =============
# Paths for WebTransport certificates (required for WebTransport protocol)
CERT_PATH=./certificates/cert.pem
KEY_PATH=./certificates/key.pem
DIGEST_PATH=./certificates/digest.txt

# ============= Database Configuration =============
# Database URL (for future use when adding persistence)
# Uncomment and configure when adding database support
# Format: postgresql://username:password@host:port/database
# DATABASE_URL=postgresql://user:password@localhost:5432/multiplayer_game

# Alternative database options:
# MySQL: mysql://user:password@localhost:3306/multiplayer_game
# SQLite: sqlite:./data/game.db

# ============= Client Configuration =============
# Client interpolation buffer (milliseconds)
# Industry standard: 100ms for smooth remote player movement
INTERPOLATION_BUFFER_MS=100

# Client input delay (frames, 0 for instant response)
# 0 recommended for client-side prediction
INPUT_DELAY_FRAMES=0

# ============= Development Configuration =============
# Enable debug mode (additional logging, debug UI)
DEBUG_MODE=false

# Enable physics debug rendering (visualize colliders, forces)
PHYSICS_DEBUG=false

# Network conditioner for testing (simulates poor network conditions)
# Uncomment to enable network simulation
# NETWORK_LATENCY_MS=50
# NETWORK_JITTER_MS=10
# NETWORK_LOSS_PERCENT=0

# ============= Production Configuration =============
# Enable production optimizations
PRODUCTION=false

# Max concurrent connections (limit simultaneous players)
MAX_CONNECTIONS=100

# Rate limiting (requests per second per client)
# Prevents spam and DoS attacks
RATE_LIMIT=60

# ============= Advanced Configuration =============
# Frame interpolation settings
# FRAME_INTERPOLATION_ENABLED=true

# Rollback correction settings
# ROLLBACK_ENABLED=true
# MAX_ROLLBACK_FRAMES=64

# Compression settings
# ENABLE_COMPRESSION=false
# COMPRESSION_LEVEL=6

# ============= Monitoring & Metrics =============
# Prometheus metrics endpoint
# METRICS_ENABLED=false
# METRICS_PORT=9090

# Health check endpoint
# HEALTH_CHECK_ENABLED=true
# HEALTH_CHECK_PORT=8080

# ============= Security =============
# Enable authentication (when implemented)
# AUTH_ENABLED=false
# AUTH_SECRET=your-secret-key-here

# Enable encryption (when implemented)
# ENCRYPTION_ENABLED=false
